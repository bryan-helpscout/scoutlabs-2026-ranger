# Copy this to .env.local and fill in your values
# Never commit .env.local to git

ANTHROPIC_API_KEY=sk-ant-...

# Slack MCP — OAuth token (xoxb-... bot token or xoxp-... user token)
# Get from: api.slack.com/apps → OAuth & Permissions
SLACK_TOKEN=xoxb-...

# HubSpot — Private App access token (pat-...), used as a Bearer token against
# the HubSpot CRM REST API (api.hubapi.com). We don't use HubSpot's MCP endpoint
# because it requires a full OAuth 2.0 authorization-code flow — Private Apps
# are the 2-click path for a stand-alone app.
#
# Create at: app.hubspot.com → Settings → Integrations → Private Apps → Create
# Required scopes:
#   crm.objects.companies.read
#   crm.objects.contacts.read
#   crm.objects.deals.read
#   crm.objects.owners.read
HUBSPOT_TOKEN=pat-...

# Slab MCP server — defaults to nonprod, override for prod
# SLAB_MCP_URL=https://hs-slab-mcp.nonprod.superscout.net/mcp

# Set SLAB_DISABLED=1 when you know you won't have VPN access (e.g. dogfooding
# locally without HS network). Skips Slab fetches entirely — cleaner than
# letting them fail and log. Default: unset (Slab enabled if reachable; the
# runtime auto-caches unreachability for 5 min after the first DNS failure).
# SLAB_DISABLED=1

# Linear MCP — API key from linear.app/settings/api
LINEAR_API_KEY=lin_api_...

# Optional: restrict which origins can call the API (leave blank for local dev)
# ALLOWED_ORIGIN=https://your-app.vercel.app

# ── Slack slash command (/ranger) ──
# Signing Secret for the Slack app that hosts /ranger. Required for the
# /api/slack/command endpoint to verify incoming requests. Get it from:
#   api.slack.com/apps → <your Ranger app> → Basic Information → Signing Secret
# SLACK_SIGNING_SECRET=...

# ── Zoom RTMS (live transcript webhook) ──
# Used by /api/zoom/events to accept Zoom's webhook events and open the
# RTMS WebSocket that streams transcripts directly into the transcript
# store (same pipeline as paste + curl ingest; triage runs identically).
#
# Prerequisites (admin setup — see README):
#   - Zoom Business+ or Enterprise plan (RTMS not available on Free/Pro)
#   - Create a Zoom Marketplace app: marketplace.zoom.us → Develop → Build App
#   - Copy the app's Client ID, Client Secret, and Secret Token here
#   - Configure Event Subscription URL → https://<your-ranger>/api/zoom/events
#   - Enable events: meeting.rtms_started, meeting.rtms_stopped
#   - Enable scope: rtms:receive:meeting_transcript
#   - Deploy Ranger to a long-running host (Render/Railway/Fly — Vercel
#     serverless times out at 10 min; RTMS needs a persistent process)
# ZOOM_CLIENT_ID=...
# ZOOM_CLIENT_SECRET=...
# ZOOM_SECRET_TOKEN=...

# ── BigQuery persistence (post-call debriefs) ──
# All optional. If BIGQUERY_PROJECT_ID isn't set, debriefs are NOT written
# to BQ (local dev keeps working). When set, every debrief is streamed
# into `<project>.<dataset>.<table>` via after() — fire-and-forget, the
# API response is never delayed by BQ outcome.
#
# Run sql/debriefs-table.sql in your target dataset before enabling.
# BIGQUERY_PROJECT_ID=my-gcp-project
# BIGQUERY_DATASET=ranger         # default: ranger
# BIGQUERY_TABLE=debriefs         # default: debriefs
#
# Credentials — prefer the inline JSON form (works on Vercel/Cloudflare
# without mounting a file). Paste the whole service-account JSON blob.
# GOOGLE_APPLICATION_CREDENTIALS_JSON={"type":"service_account","project_id":"...","private_key":"..."}
#
# Or the standard GCP file path (only works where the file exists):
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/sa.json

# ── Live call triage (event-driven cadence) ──
# Defaults are tuned for "dense but not spammy"; override to dial responsiveness.
# TRIAGE_MIN_WORDS=12             # trigger triage after this many new words
# TRIAGE_MIN_INTERVAL_MS=1200     # hard floor between triage runs (ms)
# TRIAGE_WINDOW_MS=30000          # how much transcript to look at per run (ms)
# TRIAGE_MODEL=claude-haiku-4-5   # model for the cheap triage decision
