# Copy this to .env.local and fill in your values
# Never commit .env.local to git

ANTHROPIC_API_KEY=sk-ant-...

# Slack MCP — OAuth token (xoxb-... bot token or xoxp-... user token)
# Get from: api.slack.com/apps → OAuth & Permissions
SLACK_TOKEN=xoxb-...

# HubSpot — Private App access token (pat-...), used as a Bearer token against
# the HubSpot CRM REST API (api.hubapi.com). We don't use HubSpot's MCP endpoint
# because it requires a full OAuth 2.0 authorization-code flow — Private Apps
# are the 2-click path for a stand-alone app.
#
# Create at: app.hubspot.com → Settings → Integrations → Private Apps → Create
# Required scopes:
#   crm.objects.companies.read
#   crm.objects.contacts.read
#   crm.objects.deals.read
#   crm.objects.owners.read
HUBSPOT_TOKEN=pat-...

# Slab MCP server — defaults to nonprod, override for prod
# SLAB_MCP_URL=https://hs-slab-mcp.nonprod.superscout.net/mcp

# Set SLAB_DISABLED=1 when you know you won't have VPN access (e.g. dogfooding
# locally without HS network). Skips Slab fetches entirely — cleaner than
# letting them fail and log. Default: unset (Slab enabled if reachable; the
# runtime auto-caches unreachability for 5 min after the first DNS failure).
# SLAB_DISABLED=1

# Linear MCP — API key from linear.app/settings/api
LINEAR_API_KEY=lin_api_...

# Optional: restrict which origins can call the API (leave blank for local dev)
# ALLOWED_ORIGIN=https://your-app.vercel.app

# ── Live call triage (event-driven cadence) ──
# Defaults are tuned for "dense but not spammy"; override to dial responsiveness.
# TRIAGE_MIN_WORDS=12             # trigger triage after this many new words
# TRIAGE_MIN_INTERVAL_MS=1200     # hard floor between triage runs (ms)
# TRIAGE_WINDOW_MS=30000          # how much transcript to look at per run (ms)
# TRIAGE_MODEL=claude-haiku-4-5   # model for the cheap triage decision
